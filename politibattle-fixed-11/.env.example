# ── ToolHub AI — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Required. Get this from your Render PostgreSQL dashboard.
DATABASE_URL=postgresql://user:password@host:5432/toolhub

# ── Redis (optional — falls back to in-memory if not set) ────────────────────
# Recommended for production. Stores multiplayer game rooms temporarily (4 hrs).
# Get from Render Redis, Upstash, or Railway Redis.
REDIS_URL=redis://default:password@host:6379

# ── Session secret ────────────────────────────────────────────────────────────
# Change this to a long random string in production.
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
SITE_URL=https://yourdomain.onrender.com

# ── Admin account (created automatically on first start) ─────────────────────
ADMIN_EMAIL=admin@toolhub.ai
ADMIN_PASSWORD=Admin@123

# ── Google OAuth (optional — enables real Google Sign-In) ────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add your domain to Authorised JavaScript origins
# 4. Copy the Client ID here (NO client secret needed — we use Identity Services)
GOOGLE_CLIENT_ID=394997878191-osk9fvaq9s6fm3sa5a613cbe1e5916b2.apps.googleusercontent.com

# ── Google AdSense (optional) ────────────────────────────────────────────────
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_SLOT_BANNER=1234567890
ADSENSE_SLOT_SIDEBAR=0987654321

# ── PayPal (optional — enables premium subscriptions) ────────────────────────
PAYPAL_CLIENT_ID=

# ── Data directory (optional — defaults to ./data) ───────────────────────────
# DATA_DIR=/path/to/data
